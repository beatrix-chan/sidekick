rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is logged in
    function isLoggedIn() {
      return request.auth != null;
    }
    
    // Helper: Check if user owns this document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USERS - only owner can read/write their profile
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // QUESTIONS - any logged in user can read, only author can delete
    match /questions/{questionId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isLoggedIn() && resource.data.authorId == request.auth.uid;

      // ANSWERS - nested under questions
      match /answers/{answerId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow update: if isLoggedIn(); // For helpfulCount
        allow delete: if isLoggedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    // WALK REQUESTS - any logged in user can read open requests
    match /walkRequests/{requestId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isLoggedIn() && resource.data.requesterId == request.auth.uid;
    }

    // WALK SESSIONS - only participants can read/write
    match /walkSessions/{sessionId} {
      allow read: if isLoggedIn() && 
        (resource.data.userAId == request.auth.uid || resource.data.userBId == request.auth.uid);
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && 
        (resource.data.userAId == request.auth.uid || resource.data.userBId == request.auth.uid);
      allow delete: if false; // Never delete sessions (for safety records)
    }

    // NOTIFICATIONS - only owner can read/write their notifications
    match /notifications/{notificationId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    // REPORTS - any logged-in user can submit, no client reads/updates/deletes
    match /reports/{reportId} {
      allow create: if isLoggedIn();
      allow read, update, delete: if false;
    }

    // GLOBAL CHAT - any logged-in user can read and send messages
    match /globalChat/{messageId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if false;
    }
  }
}
